------------------------------------------------------------------------
-- 2. ULTRA-RESPONSIVE DRAG SYSTEM
------------------------------------------------------------------------
local dragging = false
local dragStart, startPos

dragHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

RunService.RenderStepped:Connect(function()
    if dragging then
        local mousePos = UserInputService:GetMouseLocation()
        -- Offset mapping to accommodate TopBar offset shifts in screen spaces
        local delta = Vector2.new(mousePos.X - dragStart.X, mousePos.Y - dragStart.Y - 36) 
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

------------------------------------------------------------------------
-- 3. CLIENT-ONLY VISUAL CLONING CORE FUNCTION
------------------------------------------------------------------------
local function cloneHeldItem()
    local character = player.Character
    if character then
        local heldItem = character:FindFirstChildOfClass("Tool")
        
        if heldItem then
            local backpack = player:FindFirstChild("Backpack")
            if backpack then
                local originalArchivable = heldItem.Archivable
                heldItem.Archivable = true
                
                local clonedTool = heldItem:Clone()
                clonedTool.Parent = backpack
                
                heldItem.Archivable = originalArchivable
                print("DUPED: " .. heldItem.Name)
            end
        else
            print("Action failed: You must hold an item first!")
        end
    end
end

------------------------------------------------------------------------
-- 4. INTERACTION ANIMATIONS & KEYBINDS
------------------------------------------------------------------------
local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

cloneButton.MouseEnter:Connect(function()
    TweenService:Create(cloneButton, tweenInfo, {BackgroundColor3 = Color3.fromRGB(35, 35, 48)}):Play()
    TweenService:Create(buttonContainer, tweenInfo, {Size = UDim2.new(0, 206, 0, 52), Position = UDim2.new(0.5, -103, 0, 88)}):Play()
end)

cloneButton.MouseLeave:Connect(function()
    TweenService:Create(cloneButton, tweenInfo, {BackgroundColor3 = Color3.fromRGB(25, 25, 35)}):Play()
    TweenService:Create(buttonContainer, tweenInfo, {Size = UDim2.new(0, 200, 0, 48), Position = UDim2.new(0.5, -100, 0, 90)}):Play()
end)

cloneButton.MouseButton1Down:Connect(function()
    TweenService:Create(cloneButton, tweenInfo, {BackgroundColor3 = Color3.fromRGB(15, 15, 22)}):Play()
    cloneHeldItem()
end)

cloneButton.MouseButton1Up:Connect(function()
    TweenService:Create(cloneButton, tweenInfo, {BackgroundColor3 = Color3.fromRGB(35, 35, 48)}):Play()
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.E then
        cloneHeldItem()
    end
end)
